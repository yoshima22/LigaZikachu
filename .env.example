# Manutencao / acesso do servidor
# Fecha imediatamente. Se EMERGENCY_MAINTENANCE_UNTIL estiver no futuro,
# o site reabre automaticamente quando o horario passar, mesmo que esta env continue true.
EMERGENCY_MAINTENANCE="false"
EMERGENCY_MAINTENANCE_UNTIL=""
MAINTENANCE_MESSAGE=""

# Janela unica agendada. Use ISO com fuso, ex: 2026-06-15T18:00:00-03:00
MAINTENANCE_START_AT=""
MAINTENANCE_END_AT=""

# Varias janelas: "inicio|fim|mensagem opcional;inicio|fim|mensagem opcional"
MAINTENANCE_WINDOWS=""
