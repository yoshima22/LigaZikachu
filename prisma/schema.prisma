  rarity      ShopItemRarity  @default(COMMON)
  price       Int
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)  // ordem de exibição na loja
  // Para molduras (FRAME): { frameScale: number, frameOffsetX: number, frameOffsetY: number }
  // Para banners (BANNER): { focusX: number, focusY: number }
  metadata    Json?
  // Para títulos (TITLE): tema visual, frase de sabor e efeito de entrada
  theme           TitleTheme           @default(NEUTRAL)
  flavorText      String?              @db.Text
  entranceEffect  TitleEntranceEffect  @default(NONE)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User?           @relation("ShopItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  ownerships  PlayerInventory[]
  syncChallengeConsumptions SyncChallengeEntry[]
  @@map("shop_items")
}

model PlayerInventory {
  id          String    @id @default(cuid())
  playerId    String
  itemId      String
  equipped    Boolean   @default(false)
  quantity    Int       @default(1)
  purchasedAt DateTime  @default(now())
  // "SHOP" | "VIP_PASS" | "ADMIN_GRANT" | null
  source      String?
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  @@unique([playerId, itemId])
  @@index([playerId])
  @@map("player_inventory")
}

model SyncChallengeEntry {
  id             String              @id @default(cuid())
  playerId       String
  status         SyncChallengeStatus @default(CONSUMED)
  bansJson       Json
  consumedItemId String?
  consumedAt     DateTime            @default(now())
  cancelledAt    DateTime?
  createdAt      DateTime            @default(now())
  player         Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  consumedItem   ShopItem?           @relation(fields: [consumedItemId], references: [id], onDelete: SetNull)

  @@index([playerId, createdAt])
  @@map("sync_challenge_entries")
}

model SyncChallengeConfig {
  id                                   String   @id @default("singleton")
  ticketsEnabled                       Boolean  @default(true)
  registrationOpensAt                  DateTime?
  registrationClosesAt                 DateTime?
  round1At                             DateTime?
  round2At                             DateTime?
  round3At                             DateTime?
  tiebreakAt                           DateTime?
  rewardsAt                            DateTime?
  adminSimulationEnabled               Boolean  @default(false)
  dropFromPve                          Boolean  @default(true)
  dropFromPvp                          Boolean  @default(true)
  dropFromExpedition                   Boolean  @default(true)
  dropFromCraftingDustRecycle          Boolean  @default(true)
  dropFromTcgMatch                     Boolean  @default(true)
  pveDropChance                        Float    @default(0.05)
  pvpDropChance                        Float    @default(0.30)
  expedition3hDropChance               Float    @default(0.04)
  expedition6hDropChance               Float    @default(0.08)
  recycleDropChance                    Float    @default(0.70)
  tcgWinDropChance                     Float    @default(1.00)
  updatedAt                            DateTime @updatedAt

  @@map("sync_challenge_config")
}

model SyncTicketHalf {
  id                  String               @id @default(cuid())
  side                SyncTicketSide
  ownerId             String
  generatedByPlayerId String
  sourceAction        String
  status              SyncTicketHalfStatus @default(AVAILABLE)
  createdAt           DateTime             @default(now())
  sentAt              DateTime?
  combinedAt          DateTime?
  expiresAt           DateTime?
  owner               Player               @relation("SyncTicketHalfOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  generatedByPlayer   Player               @relation("SyncTicketHalfGeneratedBy", fields: [generatedByPlayerId], references: [id], onDelete: Cascade)
  leftTicket          SyncTicket?          @relation("SyncTicketLeftHalf")
  rightTicket         SyncTicket?          @relation("SyncTicketRightHalf")

  @@index([ownerId, status, side])
  @@index([generatedByPlayerId, createdAt])
  @@map("sync_ticket_halves")
}

model SyncTicket {
  id              String           @id @default(cuid())
  ownerId         String
  leftHalfId      String           @unique
  rightHalfId     String           @unique
  bannedUserAId   String
  bannedUserBId   String
  status          SyncTicketStatus @default(AVAILABLE)
  createdAt       DateTime         @default(now())
  consumedAt      DateTime?
  refundedAt      DateTime?
  owner           Player           @relation("SyncTicketOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  leftHalf        SyncTicketHalf    @relation("SyncTicketLeftHalf", fields: [leftHalfId], references: [id], onDelete: Restrict)
  rightHalf       SyncTicketHalf    @relation("SyncTicketRightHalf", fields: [rightHalfId], references: [id], onDelete: Restrict)
  bannedUserA     Player           @relation("SyncTicketBannedA", fields: [bannedUserAId], references: [id], onDelete: Restrict)
  bannedUserB     Player           @relation("SyncTicketBannedB", fields: [bannedUserBId], references: [id], onDelete: Restrict)
  syncTeamAsA     SyncEventTeam?   @relation("SyncEventTeamTicketA")
  syncTeamAsB     SyncEventTeam?   @relation("SyncEventTeamTicketB")

  @@index([ownerId, status, createdAt])
  @@map("sync_tickets")
}

model SyncEventTeam {
  id              String              @id @default(cuid())
  playerAId       String
  playerBId       String?
  ticketAId       String              @unique
  ticketBId       String?             @unique
  status          SyncEventTeamStatus @default(OPEN)
  confirmedA      Boolean             @default(false)
  confirmedB      Boolean             @default(false)
  lineupStatusA   SyncLineupStatus    @default(OPEN)
  lineupStatusB   SyncLineupStatus    @default(OPEN)
  roomId          String?
  roomSlot        Int?                // 1–4 dentro da sala
  createdAt       DateTime            @default(now())
  completedAt     DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  lineupReadyAt   DateTime?
  playerA         Player              @relation("SyncEventTeamPlayerA", fields: [playerAId], references: [id], onDelete: Cascade)
  playerB         Player?             @relation("SyncEventTeamPlayerB", fields: [playerBId], references: [id], onDelete: SetNull)
  ticketA         SyncTicket          @relation("SyncEventTeamTicketA", fields: [ticketAId], references: [id], onDelete: Restrict)
  ticketB         SyncTicket?         @relation("SyncEventTeamTicketB", fields: [ticketBId], references: [id], onDelete: Restrict)
  room            SyncEventRoom?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  lineups         SyncEventLineup[]
  roundSelections SyncRoundSelection[]
  matchesAsA      SyncRoundMatch[]    @relation("SyncRoundMatchTeamA")
  matchesAsB      SyncRoundMatch[]    @relation("SyncRoundMatchTeamB")
  scores          SyncEventScore[]

  @@index([status, createdAt])
  @@index([playerAId, status])
  @@index([playerBId, status])
  @@index([roomId])
  @@map("sync_event_teams")
}

model SyncEventLineup {
  id        String           @id @default(cuid())
  teamId    String
  playerId  String
  mascotId  String
  slot      Int              // 1–9
  combatRole MascotCombatRole @default(ATTACKER)
  createdAt DateTime         @default(now())

  team      SyncEventTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player           @relation("SyncEventLineupPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  mascot    Mascot           @relation("SyncEventLineupMascot", fields: [mascotId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId, slot])
  @@unique([teamId, mascotId])
  @@index([teamId, playerId])
  @@map("sync_event_lineups")
}

model SyncEventRoom {
  id          String         @id @default(cuid())
  roomIndex   Int            // 1, 2, 3 (até 3 arenas simultâneas)
  date        String         // "YYYY-MM-DD" BRT
  status      SyncRoomStatus @default(FORMING)
  formedAt    DateTime       @default(now())
  validatedAt DateTime?
  finishedAt  DateTime?
  cancelledAt DateTime?

  teams   SyncEventTeam[]
  rounds  SyncEventRound[]
  scores  SyncEventScore[]

  @@unique([date, roomIndex])
  @@index([date, status])
  @@map("sync_event_rooms")
}

model SyncEventRound {
  id                  String          @id @default(cuid())
  roomId              String
  roundNumber         Int             // 1, 2, 3; 0 = desempate
  status              SyncRoundStatus @default(PENDING)
  modifierId          String?
  scheduledAt         DateTime
  selectionsClosedAt  DateTime?
  executedAt          DateTime?

  room       SyncEventRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  modifier   SyncEventModifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)
  selections SyncRoundSelection[]
  matches    SyncRoundMatch[]

  @@unique([roomId, roundNumber])
  @@map("sync_event_rounds")
}

model SyncEventModifier {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String   @db.Text
  effectJson  Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  rounds SyncEventRound[]

  @@map("sync_event_modifiers")
}

model SyncRoundSelection {
  id         String   @id @default(cuid())
  roundId    String
  teamId     String
  playerId   String
  mascotIds  String[] // 3 mascotes escolhidos dos 9
  isAuto     Boolean  @default(false)
  selectedAt DateTime @default(now())

  round  SyncEventRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team   SyncEventTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player         @relation("SyncRoundSelectionPlayer", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roundId, playerId])
  @@map("sync_round_selections")
}

model SyncRoundMatch {
  id          String           @id @default(cuid())
  roundId     String
  teamAId     String
  teamBId     String?
  botName     String?
  result      SyncMatchResult?
  teamADamage Int              @default(0)
  teamBDamage Int              @default(0)
  survivingA  Int              @default(0)
  survivingB  Int              @default(0)
  replayJson  Json?
  executedAt  DateTime?

  round SyncEventRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamA SyncEventTeam  @relation("SyncRoundMatchTeamA", fields: [teamAId], references: [id], onDelete: Cascade)
  teamB SyncEventTeam? @relation("SyncRoundMatchTeamB", fields: [teamBId], references: [id], onDelete: Cascade)

  @@unique([roundId, teamAId, teamBId])
  @@map("sync_round_matches")
}

model SyncEventScore {
  id             String  @id @default(cuid())
  roomId         String
  teamId         String
  playerId       String
  wins           Int     @default(0)
  losses         Int     @default(0)
  draws          Int     @default(0)
  damageDone     Int     @default(0)
  damageTaken    Int     @default(0)
  survivingTotal Int     @default(0)
  finalPosition  Int?
  rewardGranted  Boolean @default(false)
  updatedAt      DateTime @updatedAt @default(now())

  room   SyncEventRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  team   SyncEventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player        @relation("SyncEventScorePlayer", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId])
  @@index([roomId, wins, damageDone])
  @@map("sync_event_scores")
}

model UserFcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("user_fcm_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ── Sistema de Mascotes ───────────────────────────────────────────────────────

enum EggType {
  COMMON
  RARE
  SPECIAL
  LAB
  EVENT
  EGG_GEN1
  EGG_GEN2
  EGG_GEN3
  EGG_GEN4
  EGG_GEN5
  EGG_GEN6
  EGG_GEN7
  EGG_GEN8
  EGG_GEN9
  EGG_GEN6PLUS
}

enum MascotMood {
  HAPPY
  EXCITED
  NEUTRAL
  TIRED
  NEEDY
  COMPETITIVE
  ANGRY
  PROUD
  HUNGRY
  CONFIDENT
}

enum MascotPersonality {
  LOYAL
  PROUD
  MISCHIEVOUS
  LAZY
  COMPETITIVE
  DRAMATIC
  PLAYFUL
  ELECTRIC
  TIMID
  CHAOTIC
}

enum ExpeditionStatus {
  ACTIVE
  COMPLETED
  CLAIMED
}

enum FoodType {
  FOOD
  SWEET
}

enum MascotArenaState {
  FREE
  ARENA
  INJURED
  RESTING
  TRACE_HIDING
  TRACE_HUNTING
}

enum ArenaTeamStatus {
  ACTIVE
  DEFEATED
  RETIRED
}

enum ArenaBattleType {
  BOT
  PVP
  OPPORTUNISTIC
}

enum ArenaBattleResult {
  ATTACKER_WIN
  DEFENDER_WIN
  DRAW
}

enum ArenaBattleStatus {
  RESOLVED
  CANCELLED
}

model MascotEgg {
  id         String          @id @default(cuid())
  playerId   String
  type       EggType         @default(COMMON)
  obtainedAt DateTime        @default(now())
  // Se vier de uma conquista/evento, guarda a origem
  origin     String?
  player     Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  incubation MascotIncubator?
  @@index([playerId])
  @@map("mascot_eggs")
}

model MascotIncubator {
  id        String    @id @default(cuid())
  playerId  String    @unique  // 1 incubadora por jogador
  eggId     String    @unique
  startedAt DateTime  @default(now())
  finishAt  DateTime
  hatched   Boolean   @default(false)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  egg       MascotEgg @relation(fields: [eggId], references: [id], onDelete: Cascade)
  @@map("mascot_incubators")
}

model Mascot {
  id               String            @id @default(cuid())
  playerId         String
  pokemonId        Int               // ID da PokéAPI
  nickname         String?
  level            Int               @default(1)
  exp              Int               @default(0)
  happiness        Int               @default(50)  // 0-100
  mood             MascotMood        @default(NEUTRAL)
  personality      MascotPersonality
  isEquipped       Boolean           @default(false)
  isFavorite       Boolean           @default(false)
  // Stats
  statForce        Int               @default(10)
  statAgility      Int               @default(10)
  statCharisma     Int               @default(10)
  statInstinct     Int               @default(10)
  statVitality     Int               @default(10)
  // Batalhas
  battleWins       Int               @default(0)
  battleLosses     Int               @default(0)
  // Timestamps
  hatchedAt        DateTime          @default(now())
  // Preserva a procedencia depois que o registro do ovo e consumido ao chocar.
  hatchedFromEggType   EggType?
  hatchedFromEggOrigin String?
  lastInteractedAt DateTime?
  lastPlayedAt     DateTime?
  lastPettedAt     DateTime?
  lastFedAt        DateTime?
  bazarListed          Boolean           @default(false)
  socialCooldownUntil  DateTime?         // rival travou interações temporariamente
  susRestBonusMinutes  Int               @default(0)
  evolutionLocked      Boolean           @default(false)
  expLocked            Boolean           @default(false)
  operationsLocked     Boolean           @default(false) // impede envio ao Bazar e uso no Laboratório
  isShiny              Boolean           @default(false) // variante shiny — sprite diferente e marcador visual
  megaEvolvedFromPokemonId Int?
  megaStoneItemId      String?
  megaEvolvedAt        DateTime?
  arenaState           MascotArenaState  @default(FREE)
  injuredAt            DateTime?
  restingUntil         DateTime?         // repouso pós-SUS (RESTING) ou cooldown arena (FREE)
  // Análise de IV/potencial feita no Laboratório (200 ZC por análise)
  analyzedAt           DateTime?         // última vez que foi analisado no Lab
  ivScore              Int?              // 0-100 (potencial futuro)
  ivRating             String?           // SSS, SS, S, A, B, C, D ou E
  analysisJson         Json?             // snapshot completo da última análise
  // Marcador pessoal de desempenho definido pelo jogador: FORTE, NEUTRO, RUIM, PESSIMO
  performanceTag       String            @default("NEUTRO")
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  expeditions      MascotExpedition[]
  arenaTeamMembers ArenaTeamMember[]
  relationsAsA     MascotRelation[]  @relation("MascotRelationA")
  relationsAsB     MascotRelation[]  @relation("MascotRelationB")
  socialEventsAsA  MascotSocialEvent[] @relation("MascotSocialEventMascotA")
  socialEventsAsB  MascotSocialEvent[] @relation("MascotSocialEventMascotB")
  socialDecisionLogsAsA MascotSocialDecisionLog[] @relation("MascotSocialDecisionMascotA")
  socialDecisionLogsAsB MascotSocialDecisionLog[] @relation("MascotSocialDecisionMascotB")
  events           MascotEvent[]
  progressMilestones MascotProgressMilestone[]
  buffs            MascotBuff[]
  syncLineups      SyncEventLineup[] @relation("SyncEventLineupMascot")
  traceRoomsAsHider  TraceRoom[] @relation("TraceRoomHiderMascot")
  traceRoomsAsHunter TraceRoom[] @relation("TraceRoomHunterMascot")
  @@index([playerId])
  @@map("mascots")
}

model PlayerPokemonDex {
  id              String   @id @default(cuid())
  playerId        String
  pokemonId       Int
  firstObtainedAt DateTime @default(now())
  source          String?
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, pokemonId])
  @@index([playerId])
  @@index([pokemonId])
  @@map("player_pokemon_dex")
}

model PlayerPokemonWishlist {
  id        String   @id @default(cuid())
  playerId  String
  pokemonId Int
  note      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, pokemonId])
  @@index([playerId, sortOrder])
  @@index([pokemonId])
  @@map("player_pokemon_wishlist")
}

enum MascotRelationType {
  FRIEND
  RIVAL
}

model MascotRelation {
  id               String             @id @default(cuid())
  mascotAId        String
  mascotBId        String
  type             MascotRelationType @default(RIVAL)
  relationshipScore Int               @default(0)
  specialBondType   String?
  wins             Int                @default(0)
  losses           Int                @default(0)
  interactionCount Int                @default(1)  // sobe com eventos; determina tier
  lastInteractionAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  mascotA   Mascot             @relation("MascotRelationA", fields: [mascotAId], references: [id], onDelete: Cascade)
  mascotB   Mascot             @relation("MascotRelationB", fields: [mascotBId], references: [id], onDelete: Cascade)
  @@unique([mascotAId, mascotBId])
  @@index([mascotAId, relationshipScore])
  @@index([mascotBId, relationshipScore])
  @@map("mascot_relations")
}

enum MascotSocialEventStatus {
  PENDING
  RESOLVED
  AUTO_RESOLVED
  EXPIRED
  CANCELLED
}

enum MascotSocialVisibility {
  PRIVATE
  INVOLVED_PLAYERS
  PUBLIC
}

model MascotSocialEvent {
  id                  String                  @id @default(cuid())
  ownerId             String
  mascotAId           String
  mascotBId           String?
  eventType           String
  title               String
  description         String
  status              MascotSocialEventStatus @default(PENDING)
  optionsJson         Json?
  resultJson          Json?
  visibility          MascotSocialVisibility  @default(PRIVATE)
  affectedPlayerIds   Json?
  publicEligible      Boolean                 @default(false)
  resolvedByPlayerId  String?
  resolvedOptionId    String?
  resolvedBy          String?
  autoResolveStrategy String?
  parentEventId       String?
  isFollowUp          Boolean                 @default(false)
  followUpCount       Int                     @default(0)
  maxFollowUps        Int                     @default(1)
  expiresAt           DateTime?
  resolvedAt          DateTime?
  autoResolvedAt      DateTime?
  createdAt           DateTime                @default(now())

  owner            Player  @relation("MascotSocialEventOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  resolvedByPlayer Player? @relation("MascotSocialEventResolver", fields: [resolvedByPlayerId], references: [id], onDelete: SetNull)
  mascotA          Mascot  @relation("MascotSocialEventMascotA", fields: [mascotAId], references: [id], onDelete: Cascade)
  mascotB          Mascot? @relation("MascotSocialEventMascotB", fields: [mascotBId], references: [id], onDelete: Cascade)
  decisions        MascotSocialDecisionLog[]

  @@index([ownerId, status, createdAt])
  @@index([mascotAId])
  @@index([mascotBId])
  @@index([eventType])
  @@index([expiresAt])
  @@map("mascot_social_events")
}

model MascotSocialDecisionLog {
  id                String                 @id @default(cuid())
  eventId           String
  actorPlayerId     String?
  affectedPlayerIds Json?
  mascotAId         String
  mascotBId         String?
  optionId          String?
  optionLabel       String?
  optionType        String
  resolvedBy        String
  costJson          Json?
  resultJson        Json?
  visibility        MascotSocialVisibility @default(PRIVATE)
  createdAt         DateTime               @default(now())

  event       MascotSocialEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actorPlayer Player?           @relation(fields: [actorPlayerId], references: [id], onDelete: SetNull)
  mascotA     Mascot            @relation("MascotSocialDecisionMascotA", fields: [mascotAId], references: [id], onDelete: Cascade)
  mascotB     Mascot?           @relation("MascotSocialDecisionMascotB", fields: [mascotBId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([actorPlayerId, createdAt])
  @@index([mascotAId, createdAt])
  @@index([mascotBId, createdAt])
  @@map("mascot_social_decision_logs")
}

model MascotEvent {
  id          String   @id @default(cuid())
  mascotId    String
  emoji       String   @default("📝")
  description String
  createdAt   DateTime @default(now())
  mascot      Mascot   @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId, createdAt])
  @@map("mascot_events")
}

model MascotProgressMilestone {
  id        String   @id @default(cuid())
  mascotId String
  key       String
  label     String
  level     Int
  statsJson Json
  createdAt DateTime @default(now())
  mascot    Mascot   @relation(fields: [mascotId], references: [id], onDelete: Cascade)

  @@unique([mascotId, key])
  @@index([mascotId])
  @@map("mascot_progress_milestones")
}

model MascotExpedition {
  id         String          @id @default(cuid())
  mascotId   String
  startedAt  DateTime        @default(now())
  finishAt   DateTime
  status     ExpeditionStatus @default(ACTIVE)
  rewardJson Json?
  mascot     Mascot          @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId])
  @@map("mascot_expeditions")
}

enum MascotBuffType {
  EXP_BOOST
  STAT_BOOST
  HAPPINESS
  LUCK_BOOST
  MOOD_RESET
  LUCKY_EGG
  WEAKNESS_POLICY
  PICNIC_BASKET
  XP_SHARE
  VACATION
}

model MascotBuff {
  id        String        @id @default(cuid())
  mascotId  String
  type      MascotBuffType
  expiresAt DateTime
  createdAt DateTime      @default(now())
  mascot    Mascot        @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId, expiresAt])
  @@map("mascot_buffs")
}

model MascotFoodItem {
  id       String   @id @default(cuid())
  playerId String
  type     FoodType
  quantity Int      @default(1)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([playerId, type])
  @@map("mascot_food_items")
}

model ArenaTeam {
  id             String          @id @default(cuid())
  playerId       String
  name           String
  status         ArenaTeamStatus @default(ACTIVE)
  vaultCoins     Int             @default(0)
  vaultExp       Int             @default(0)
  vaultFood      Int             @default(0)
  vaultSweet     Int             @default(0)
  multiplier     Decimal         @default(1) @db.Decimal(5, 2)
  roomLevel      Int             @default(0)       // sala: 10, 20, ..., 100 (max nível permitido)
  isTraining     Boolean         @default(false)   // sala de treinamento: sem lesões, sem loot, sem ranking
  pendingBotJson Json?
  pendingBotDifficulty String?
  lastPassiveIncomeAt DateTime    @default(now())
  enteredAt      DateTime        @default(now())
  lastBattleAt   DateTime?       // última batalha PvP
  lastPveBattleAt DateTime?      // última batalha PvE (cooldown separado)
  retiredAt      DateTime?       // set quando retirou COM recompensas ≥ 1 ZC (gera cooldown de 10 min)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  player         Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  members        ArenaTeamMember[]
  attacks        ArenaBattle[]   @relation("ArenaBattleAttackTeam")
  defenses       ArenaBattle[]   @relation("ArenaBattleDefenseTeam")

  @@index([playerId, status])
  @@map("arena_teams")
}

model ArenaTeamMember {
  id        String    @id @default(cuid())
  teamId    String
  mascotId  String
  slot      Int
  combatRole MascotCombatRole @default(ATTACKER)
  joinedAt  DateTime  @default(now())

  team      ArenaTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  mascot    Mascot    @relation(fields: [mascotId], references: [id], onDelete: Cascade)

  @@unique([teamId, slot])
  @@unique([teamId, mascotId])
  @@index([mascotId])
  @@map("arena_team_members")
}

model ArenaBattle {
  id               String            @id @default(cuid())
  type             ArenaBattleType
  status           ArenaBattleStatus @default(RESOLVED)
  result           ArenaBattleResult
  attackerPlayerId String?
  defenderPlayerId String?
  attackTeamId     String?
  defenseTeamId    String?
  botName          String?
  levelBandMin     Int?
  levelBandMax     Int?
  winnerPlayerId   String?
  loserPlayerId    String?
  rounds           Int               @default(0)
  turnLog          Json
  lootResult       Json?
  injuredMascotIds Json?
  seenByDefender   Boolean           @default(false) // true após defensor visualizar o ataque
  createdAt        DateTime          @default(now())

  attackerPlayer   Player?           @relation("ArenaBattleAttacker", fields: [attackerPlayerId], references: [id], onDelete: SetNull)
  defenderPlayer   Player?           @relation("ArenaBattleDefender", fields: [defenderPlayerId], references: [id], onDelete: SetNull)
  attackTeam       ArenaTeam?        @relation("ArenaBattleAttackTeam", fields: [attackTeamId], references: [id], onDelete: SetNull)
  defenseTeam      ArenaTeam?        @relation("ArenaBattleDefenseTeam", fields: [defenseTeamId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([attackerPlayerId])
  @@index([defenderPlayerId])
  @@map("arena_battles")
}

model ArenaGroundSpoil {
  id              String    @id @default(cuid())
  sourceBattleId  String?
  sourcePlayerId  String?
  foundByPlayerId String?
  coins           Int       @default(0)
  exp             Int       @default(0)
  food            Int       @default(0)
  sweet           Int       @default(0)
  itemPayload     Json?
  status          String    @default("AVAILABLE") // AVAILABLE | CLAIMED | EXPIRED
  createdAt       DateTime  @default(now())
  claimedAt       DateTime?

  @@index([status, createdAt])
  @@index([sourcePlayerId])
  @@index([foundByPlayerId])
  @@map("arena_ground_spoils")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Bazar da Liga ─────────────────────────────────────────────────────────────

enum BazarListingType {
  SALE
  TRADE
  SALE_OR_TRADE
  AUCTION
}

enum BazarListingStatus {
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  CANCELLED
}

enum BazarItemCategory {
  MASCOT
  ITEM
  COSMETIC
}

enum BazarProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// Anúncio do Bazar
model BazarListing {
  id           String             @id @default(cuid())
  playerId     String
  category     BazarItemCategory
  listingType  BazarListingType
  status       BazarListingStatus @default(ACTIVE)

  // O que está sendo vendido/trocado (JSON flexível)
  // Mascot:   { mascotId, pokemonId, pokemonName, level, nickname, personality, stats }
  // Item:     { itemType, quantity, displayName }
  // Cosmetic: { inventoryItemId, itemType, displayName }
  payload      Json

  priceCoins   Int?     // null = troca somente
  wantedDesc   String?  // texto livre descrevendo o que quer em troca
  description  String?

  feeCharged   Int      @default(0)
  views        Int      @default(0)
  expiresAt    DateTime

  // Campos de leilão (null para anúncios normais)
  minBidCoins        Int?
  currentBidCoins    Int?
  currentBidPlayerId String?
  auctionEndsAt      DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player       Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  proposals    BazarProposal[]
  favorites    BazarFavorite[]
  auctionBids  BazarAuctionBid[]

  @@index([category, status, createdAt])
  @@index([playerId])
  @@map("bazar_listings")
}

model BazarAuctionBid {
  id        String   @id @default(cuid())
  listingId String
  playerId  String
  amount    Int
  createdAt DateTime @default(now())

  listing   BazarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  player    Player       @relation(fields: [playerId], references: [id])

  @@index([listingId, createdAt])
  @@map("bazar_auction_bids")
}

// Proposta de troca/compra
model BazarProposal {
  id          String              @id @default(cuid())
  listingId   String
  proposerId  String

  coinsOffer  Int                 @default(0)
  coinsEscrowed Boolean           @default(false)
  // JSON: [{type:"ITEM", itemType, quantity, displayName}]
  itemsOffer  Json?
  message     String?

  status      BazarProposalStatus @default(PENDING)
  viewedByProposerAt DateTime?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  listing     BazarListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  proposer    Player        @relation(fields: [proposerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([proposerId])
  @@map("bazar_proposals")
}

// Favoritos
model BazarFavorite {
  id        String       @id @default(cuid())
  playerId  String
  listingId String
  createdAt DateTime     @default(now())

  player    Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  listing   BazarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([playerId, listingId])
  @@map("bazar_favorites")
}

// Histórico de transações (feed público)
model BazarTransaction {
  id          String   @id @default(cuid())
  listingId   String
  sellerId    String
  buyerId     String
  sellerName  String
  buyerName   String
  description String   // ex: "Pikachu Nv.5 vendido por 1500 ZC"
  coinsAmount Int      @default(0)
  category    BazarItemCategory

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("bazar_transactions")
}

// Configuração do Miauvadão (NPC intermediário — singleton)
model BazarPlayerTradeBan {
  id              String   @id @default(cuid())
  playerAId       String
  playerBId       String
  reason           String?
  createdByUserId String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([playerAId, playerBId])
  @@index([playerAId, active])
  @@index([playerBId, active])
  @@map("bazar_player_trade_bans")
}

model MiauvadaoConfig {
  id                String   @id @default("singleton")
  vaultBalance      Int      @default(0)
  listingFee        Int      @default(10)
  dailyOffers       Json     @default("[]")
  offersRefreshedAt    DateTime?
  playerRefreshData    Json      @default("{}")   // { playerId: { date: "YYYY-MM-DD", count: N, lastAt: ISO } }
  // Shell Game — última mensagem do NPC
  lastWinnerMessage String?
  lastWinnerAt      DateTime?
  lastNpcMessage    String?
  lastNpcMessageAt  DateTime?
  updatedAt         DateTime @updatedAt

  @@map("miauvadao_config")
}

// ── Passe Apoiador ────────────────────────────────────────────────────────────

model SupporterPass {
  id               String               @id @default(cuid())
  playerId         String
  active           Boolean              @default(true)
  passLabel        String               @default("Passe Apoiador")
  startsAt         DateTime             @default(now())
  expiresAt        DateTime
  // VIP title ShopItem id granted to the player
  titleItemId      String?
  createdByAdminId String?
  revokedByAdminId String?
  revokedAt              DateTime?
  revokeReason           String?
  allowRetroactiveClaims Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  player           Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  claims           SupporterPassClaim[]

  @@index([playerId])
  @@index([active, expiresAt])
  @@map("supporter_passes")
}

model SupporterPassClaim {
  id            String    @id @default(cuid())
  passId        String
  playerId      String
  dayNumber     Int       // 1–30
  rewardType    String    // "COINS" | "EGG" | "FOOD" | "SWEET" | "STICKER_PACK" | "SHOP_ITEM" | "ZIKALOOT"
  rewardPayload Json
  claimedAt     DateTime  @default(now())

  pass          SupporterPass @relation(fields: [passId], references: [id], onDelete: Cascade)

  @@unique([passId, dayNumber])
  @@index([playerId])
  @@map("supporter_pass_claims")
}

// Sessão de Shell Game — guarda posição da bolinha no servidor (anti-cheat)
model ShellGameSession {
  id         String   @id @default(cuid())
  playerId   String
  betAmount  Int
  ballPos    Int      // 0 | 1 | 2  — segredo até o palpite
  resolved   Boolean  @default(false)
  won        Boolean?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("shell_game_sessions")
}

// Configuração customizável do calendário do Passe Apoiador
model PassScheduleConfig {
  id        String   @id @default("singleton")
  schedule  Json     // DayReward[] — 30 itens
  allowRetroactiveClaims Boolean  @default(false)
  displayTitle String?
  description  String?
  flavorText   String?
  updatedAt DateTime @updatedAt
  updatedBy String?  // userId do admin que salvou por último

  @@map("pass_schedule_config")
}

// ── Liga Semanal dos Mascotes ──────────────────────────────────

model WeeklyMascotLeague {
  id               String              @id @default(cuid())
  weekKey          String              @unique // e.g. "2026-W26"
  weekStart        DateTime
  weekEnd          DateTime
  status           WeeklyLeagueStatus  @default(REGISTRATION)
  modifierJson     Json?               // {id, name, description, effectType, bonusPct, ...}
  championPlayerId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  participants     WeeklyMascotLeagueParticipant[]
  dailyTeams       WeeklyMascotLeagueDailyTeam[]
  matches          WeeklyMascotLeagueMatch[]
  battleItems      WeeklyMascotLeagueBattleItem[]
  mascotStats      WeeklyMascotLeagueMascotStats[]

  @@map("weekly_mascot_leagues")
}

model WeeklyMascotLeagueParticipant {
  id             String   @id @default(cuid())
  leagueId       String
  playerId       String
  points         Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  draws          Int      @default(0)
  woLosses       Int      @default(0)
  byes           Int      @default(0)
  survivorsScore Int      @default(0)
  damageDealt    Int      @default(0)
  damageTaken    Int      @default(0)
  finalRank      Int?
  rewardGranted  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  league         WeeklyMascotLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([leagueId])
  @@map("weekly_mascot_league_participants")
}

model WeeklyMascotLeagueDailyTeam {
  id            String    @id @default(cuid())
  leagueId      String
  playerId      String
  battleDate    String    // "YYYY-MM-DD"
  battleSlot    Int       // 1, 2, or 3
  source        String    @default("MANUAL") // MANUAL | AUTO_FAVORITE | AUTO_COLLECTION
  mascotIdsJson Json      // string[] of mascot IDs
  rolesJson     Json?     // Record<mascotId, CombatRole>
  lockedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  league        WeeklyMascotLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId, battleDate, battleSlot])
  @@index([leagueId, battleDate])
  @@map("weekly_mascot_league_daily_teams")
}

model WeeklyMascotLeagueMatch {
  id                  String             @id @default(cuid())
  leagueId            String
  roundNumber         Int
  battleDate          String             // "YYYY-MM-DD"
  battleSlot          Int                // 1, 2, or 3
  scheduledAt         DateTime
  playerAId           String
  playerBId           String?
  winnerId            String?
  loserId             String?
  isDraw              Boolean            @default(false)
  playerASurvivors    Int                @default(0)
  playerBSurvivors    Int                @default(0)
  playerADamageDealt  Int                @default(0)
  playerBDamageDealt  Int                @default(0)
  playerADamageTaken  Int                @default(0)
  playerBDamageTaken  Int                @default(0)
  resultJson          Json?
  replayJson          Json?
  status              WeeklyMatchStatus  @default(SCHEDULED)
  resolvedAt          DateTime?
  createdAt           DateTime           @default(now())
  league              WeeklyMascotLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  battleItems         WeeklyMascotLeagueBattleItem[]
  bets                WeeklyMascotLeagueBet[]

  @@index([leagueId, battleDate])
  @@index([playerAId])
  @@index([playerBId])
  @@map("weekly_mascot_league_matches")
}

model WeeklyMascotLeagueBattleItem {
  id             String                    @id @default(cuid())
  leagueId       String
  matchId        String?
  playerId       String
  itemId         String
  effectType     String                    // POSITIVE or NEGATIVE
  targetType     String                    // SELF or OPPONENT
  targetPlayerId String?
  battleDate     String
  battleSlot     Int
  consumedAt     DateTime?
  refundedAt     DateTime?
  createdAt      DateTime                  @default(now())
  league         WeeklyMascotLeague        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match          WeeklyMascotLeagueMatch?  @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([leagueId, battleDate])
  @@index([playerId])
  @@map("weekly_mascot_league_battle_items")
}

model WeeklyMascotLeagueMascotStats {
  id               String   @id @default(cuid())
  leagueId         String
  mascotId         String
  ownerId          String
  combatRole       String
  matchesPlayed    Int      @default(0)
  wins             Int      @default(0)
  losses           Int      @default(0)
  damageDealt      Int      @default(0)
  damageTaken      Int      @default(0)
  kosDealt         Int      @default(0)
  kosReceived      Int      @default(0)
  buffsApplied     Int      @default(0)
  debuffsApplied   Int      @default(0)
  interceptions    Int      @default(0)
  successfulFlanks Int      @default(0)
  healingDone      Int      @default(0)
  turnsSurvived    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  league           WeeklyMascotLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, mascotId])
  @@index([leagueId])
  @@map("weekly_mascot_league_mascot_stats")
}

// Conteúdo editável do site (textos do manual, etc.)
model SiteContent {
  id        String   @id  // ex: "manual"
  data      Json     @default("{}")  // Record<string, string> — chave → texto
  updatedAt DateTime @updatedAt
  updatedBy String?  // userId do admin que editou por último

  @@map("site_content")
}

// ── Caçada de Rastros ─────────────────────────────────────────────────────────

enum TraceRouteType {
  SHORT
  MEDIUM
  LONG
  WEEKLY
}

enum TraceRoomStatus {
  WAITING
  HUNTING
  FOUND
  ESCAPED
  CANCELLED
}

enum TraceTarget {
  HIDER
  HUNTER
}

model TraceRoom {
  id               String          @id @default(cuid())
  hiderId          String
  hiderMascotId    String
  hunterId         String?
  hunterMascotId   String?
  routeType        TraceRouteType
  routePath        String          // JSON: ["N","S","L","O"]
  focusPoints      Int             // remaining hider focus
  maxFocus         Int             // initial focus (= steps + vitality bonus)
  currentStep      Int             @default(0)
  status           TraceRoomStatus @default(WAITING)
  lastHunterMoveAt DateTime?
  sinalizadorUsed  Boolean         @default(false)
  skipNextMove     Boolean         @default(false) // event: hunter skips next move
  hintDirection    String?         // event-revealed correct direction hint
  isAdminSim       Boolean         @default(false)
  expiresAt        DateTime
  resolvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  hider            Player          @relation("TraceRoomHider", fields: [hiderId], references: [id], onDelete: Cascade)
  hiderMascot      Mascot          @relation("TraceRoomHiderMascot", fields: [hiderMascotId], references: [id], onDelete: Cascade)
  hunter           Player?         @relation("TraceRoomHunter", fields: [hunterId], references: [id], onDelete: Cascade)
  hunterMascot     Mascot?         @relation("TraceRoomHunterMascot", fields: [hunterMascotId], references: [id], onDelete: Cascade)
  moves            TraceMove[]
  randomEvents     TraceRoomEvent[]
  eventLogs        TraceEventLog[]
  @@index([hiderId])
  @@index([hunterId])
  @@index([status])
  @@map("trace_rooms")
}

model TraceMove {
  id        String    @id @default(cuid())
  roomId    String
  step      Int
  direction String
  correct   Boolean
  createdAt DateTime  @default(now())
  room      TraceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  @@index([roomId])
  @@map("trace_moves")
}

model TraceRoomEvent {
  id            String      @id @default(cuid())
  roomId        String
  eventCode     String
  target        TraceTarget
  step          Int
  effectApplied Boolean     @default(false)
  createdAt     DateTime    @default(now())
  room          TraceRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  @@index([roomId])
  @@map("trace_room_events")
}

model TraceEventLog {
  id          String     @id @default(cuid())
  roomId      String?
  description String     @db.Text
  playerName  String
  createdAt   DateTime   @default(now())
  room        TraceRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  @@index([createdAt])
  @@map("trace_event_logs")
}

model GoldenPawTransaction {
  id        String   @id @default(cuid())
  playerId  String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@index([playerId])
  @@map("golden_paw_transactions")
}

// ── Evento Ordem da Trapaca / Raid Boss ──────────────────────────────────────

enum RaidEventPhase {
  ANNOUNCED
  INVESTIGATION
  HIDEOUT_UNLOCKING
  HIDEOUT_FOUND
  RAID_ACTIVE
  RAID_DEFEATED
  RAID_FAILED
  ENDED
}

enum RaidSabotageSystem {
  BAZAR
  SUS
  LABORATORY
  ZIKASHOP
  ZIKALOOT
  PROFILE
  MASCOTS
  DASHBOARD
  SYNC_CHALLENGE
  MASCOT_LEAGUE
}

enum RaidSabotageType {
  BLOCK_BAZAR_SLOT
  INCREASE_PRICE
  DISABLE_LAB_ANALYSIS
  DISABLE_DUST_CONVERSION
  ZIKALOOT_FAKE_NUMBER
  PROFILE_GRAFFITI
  HIDDEN_INTERACTION
  MASCOT_SPEECH_OVERRIDE
}

enum RaidClueRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  FAKE
}

enum RaidClueQuality {
  GOOD
  OK
  BAD
  JOKE
  MISLEADING
}

enum RaidInteractionType {
  CLICK
  MULTI_CLICK
  DRAG
  CLICK_SEQUENCE
  HIDDEN_BUTTON
}

enum RaidBattleResult {
  WIN
  LOSS
  DRAW
}

enum RaidNotificationType {
  ORDER_INTRO
  ORDER_REWARD_ZIKALOOT
  ORDER_REWARD_BAZAR
  ORDER_REWARD_LAB
  ORDER_REWARD_LEAGUE
  ORDER_REWARD_MASCOTS
  HIDEOUT_FOUND
  MEGA_ACTIVATED
  RAID_DEFEATED
  ORDER_FREE_MEGA_STONE
  RAID_FAILED
}

model RaidEvent {
  id                     String          @id @default(cuid())
  name                   String
  slug                   String          @unique
  villainGroupName       String          @default("Ordem da Trapaca")
  phase                  RaidEventPhase  @default(ANNOUNCED)
  startsAt               DateTime?
  investigationStartsAt  DateTime?
  hideoutFoundAt         DateTime?
  hideoutFoundByUserId   String?
  raidStartsAt           DateTime?
  raidEndsAt             DateTime?
  bossName               String          @default("Capitao Trambique")
  bossMascotName         String          @default("Mega Sableye Trapaceiro")
  bossPokemonId          Int             @default(302)
  bossMegaPokemonId      Int             @default(10066)
  bossHpMax              Int             @default(1000000)
  bossHpCurrent          Int             @default(1000000)
  megaActivatedAt        DateTime?
  megaThresholdPercent   Int             @default(30)
  bossConfigJson         Json?
  active                 Boolean         @default(false)
  localOnly              Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  sabotages      RaidSabotage[]
  clues          RaidClue[]
  mysterySteps   RaidMysteryStep[]
  interactions   RaidHiddenInteraction[]
  battleAttempts RaidBattleAttempt[]
  rankings       RaidDamageRanking[]
  notifications  UserRaidNotification[]
  passwords      RaidPassword[]
  passwordStamps RaidPasswordStamp[]

  @@index([active, phase])
  @@map("raid_events")
}

model RaidSabotage {
  id               String             @id @default(cuid())
  raidEventId      String
  systemKey        RaidSabotageSystem
  sabotageType     RaidSabotageType
  title            String
  description      String?            @db.Text
  effectJson       Json?
  startsAt         DateTime?
  endsAt           DateTime?
  active           Boolean            @default(false)
  visibleToPlayers Boolean            @default(true)
  severity         Int                @default(1)
  adminNotes       String?            @db.Text
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  event            RaidEvent          @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@index([raidEventId, active, systemKey])
  @@map("raid_sabotages")
}

model RaidClue {
  id             String          @id @default(cuid())
  raidEventId    String
  clueText       String          @db.Text
  rarity         RaidClueRarity  @default(COMMON)
  quality        RaidClueQuality @default(OK)
  relatedStepKey String?
  visible        Boolean         @default(false)
  releasedAt     DateTime?
  discoveredAt   DateTime?
  discoveredByPlayerId String?
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  event          RaidEvent       @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  discoveredBy   Player?         @relation("RaidClueDiscoverer", fields: [discoveredByPlayerId], references: [id], onDelete: SetNull)

  @@unique([raidEventId, sortOrder])
  @@index([raidEventId, visible, releasedAt])
  @@index([raidEventId, discoveredByPlayerId])
  @@map("raid_clues")
}

model RaidMysteryStep {
  id                      String              @id @default(cuid())
  raidEventId             String
  stepKey                 String
  pageKey                 String
  requiredVisibleClues    Int                 @default(0)
  requiredPreviousStepKey String?
  interactionType         RaidInteractionType
  targetKey               String
  successFeedback         String              @db.Text
  earlyFeedback           String?             @db.Text
  resolvedByUserId        String?
  resolvedAt              DateTime?
  active                  Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  event                   RaidEvent           @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, stepKey])
  @@index([raidEventId, active, pageKey])
  @@map("raid_mystery_steps")
}

model RaidHiddenInteraction {
  id                  String              @id @default(cuid())
  raidEventId          String
  stepKey              String
  pageKey              String
  interactionType      RaidInteractionType
  targetSelectorOrKey  String
  solutionJson         Json?
  requiredVisibleClues Int                 @default(0)
  foundByUserId        String?
  foundAt              DateTime?
  active               Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  event                RaidEvent           @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, stepKey, targetSelectorOrKey])
  @@index([raidEventId, pageKey, active])
  @@map("raid_hidden_interactions")
}

model RaidPassword {
  id             String    @id @default(cuid())
  raidEventId    String
  passwordHash   String
  passwordLength Int       @default(6)
  debugPassword  String?
  solvedByUserId String?
  solvedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  event          RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@index([raidEventId, createdAt])
  @@map("raid_passwords")
}

model RaidPasswordStamp {
  id            String    @id @default(cuid())
  raidEventId   String
  userId        String
  displayedCode String
  greenIndex    Int
  greenDigit    String
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, userId])
  @@index([raidEventId, active])
  @@map("raid_password_stamps")
}

model RaidBattleAttempt {
  id                  String           @id @default(cuid())
  raidEventId          String
  playerId            String
  teamSnapshotJson    Json
  bossSnapshotJson    Json
  damageToBoss        Int              @default(0)
  participationPoints Int              @default(0)
  result              RaidBattleResult
  replayJson          Json?
  startedAt           DateTime         @default(now())
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  event               RaidEvent        @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  player              Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([raidEventId, playerId, createdAt])
  @@map("raid_battle_attempts")
}

model RaidDamageRanking {
  id                  String    @id @default(cuid())
  raidEventId          String
  playerId            String
  totalDamage         Int       @default(0)
  battleCount         Int       @default(0)
  highestSingleDamage Int       @default(0)
  participationPoints Int       @default(0)
  megaPhaseAttempts   Int       @default(0)
  lastBattleAt        DateTime?
  rank                Int?
  rewardGranted       Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  event               RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  player              Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, playerId])
  @@index([raidEventId, totalDamage])
  @@map("raid_damage_rankings")
}

model UserRaidNotification {
  id               String               @id @default(cuid())
  raidEventId       String
  userId           String
  notificationType RaidNotificationType
  seenAt           DateTime?
  createdAt        DateTime             @default(now())
  event            RaidEvent            @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, userId, notificationType])
  @@index([userId, seenAt])
  @@map("user_raid_notifications")
}
