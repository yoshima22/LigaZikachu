generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PLAYER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  FINISHED
  ARCHIVED
}

// Status para torneios independentes (2ª edição em diante)
enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  IN_PROGRESS
  FINISHED
}

enum TournamentFormat {
  ONLINE
  IN_PERSON
}

// Modos especiais de semana conforme regulamento
enum WeekMode {
  PADRAO
  GLC
  DUPLAS_SINCRONIZADAS
  PONTUACAO_DOBRADA
  CONSTRUTOR_MISTERIOSO
  GUERRA_DE_TIMES
  BATALHA_FINAL
}

enum WeekStatus {
  PLANNED
  OPEN
  LOCKED
  CLOSED
}

enum MatchStatus {
  DRAFT
  PENDING_CONFIRMATION
  CONFIRMED
  DISPUTED
  CANCELED
}

enum ResultSource {
  MANUAL
  ADMIN_ADJUSTMENT
  IMPORTED
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum DeckSubmissionStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum ChallengeStatus {
  OPEN
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  RESOLVED
}

enum ChallengeType {
  BADGE
  FREE
}

enum BoosterCodeStatus {
  AVAILABLE
  ASSIGNED
  REDEEMED
  INVALIDATED
  EXPIRED
}

enum DistributionStatus {
  ASSIGNED
  REDEEMED
  REVOKED
  EXPIRED
}

enum DistributionReason {
  TOP_OF_DAY
  PARTICIPATION
  WEEKLY_WINNER
  SEASON_REWARD
  MANUAL_ADJUSTMENT
}

enum SnapshotType {
  WEEKLY
  SEASONAL
  MANUAL_RECALC
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model User {
  id                       String               @id @default(cuid())
  name                     String?
  email                    String               @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  role                     Role                 @default(PLAYER)
  status                   UserStatus           @default(PENDING_APPROVAL)
  approvedById             String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  approvedBy               User?                @relation("UserApprovals", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedUsers            User[]               @relation("UserApprovals")
  player                   Player?
  accounts                 Account[]
  sessions                 Session[]
  createdSeasons           Season[]             @relation("SeasonCreatedBy")
  createdMatches           Match[]              @relation("MatchCreatedBy")
  reportedMatches          Match[]              @relation("MatchReportedBy")
  confirmedMatches         Match[]              @relation("MatchConfirmedBy")
  approvedDecks            DeckSubmission[]     @relation("DeckApprovedBy")
  openedChallenges         Challenge[]          @relation("ChallengeOpenedBy")
  resolvedChallenges       Challenge[]          @relation("ChallengeResolvedBy")
  createdBoosterCodes      BoosterCode[]        @relation("BoosterCodeCreatedBy")
  invalidatedCodes         BoosterCode[]        @relation("BoosterCodeInvalidatedBy")
  assignedDistributions    CodeDistribution[]   @relation("CodeAssignedBy")
  revokedDistributions     CodeDistribution[]   @relation("CodeRevokedBy")
  createdAchievements      Achievement[]        @relation("AchievementCreatedBy")
  generatedSnapshots       RankingSnapshot[]    @relation("RankingSnapshotGeneratedBy")
  awardedPlayerAchievements PlayerAchievement[] @relation("PlayerAchievementAwardedBy")
  auditLogs                AuditLog[]           @relation("AuditActor")
  createdTournaments       Tournament[]         @relation("TournamentCreatedBy")
  decidedRegistrations     TournamentRegistration[] @relation("RegistrationDecidedBy")
  createdLeagueBadges      LeagueBadge[]        @relation("LeagueBadgeCreatedBy")
  awardedPlayerBadges      PlayerBadge[]        @relation("PlayerBadgeAwardedBy")
  coinAdjustments          ZikaCoinTransaction[] @relation("ZkTxAdmin")
  fcmTokens                UserFcmToken[]
  createdShopItems         ShopItem[]           @relation("ShopItemCreatedBy")
  createdZikaLoots         ZikaLoot[]           @relation("ZikaLootCreatedBy")
  tutorialProgress         UserTutorialProgress[]
  passwordResetTokens      PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model UserTutorialProgress {
  id          String    @id @default(cuid())
  userId      String
  pageId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@map("user_tutorial_progress")
}

model Player {
  id                      String               @id @default(cuid())
  userId                  String               @unique
  displayName             String
  whatsapp                String?
  ptcglNick               String?              @unique
  popId                   String?              // ID do jogador em torneios oficiais Pokémon (Play! Pokémon ID)
  avatarUrl               String?
  active                  Boolean              @default(true)
  notes                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonEntries           SeasonPlayer[]
  matchesAsPlayerA        Match[]              @relation("MatchPlayerA")
  matchesAsPlayerB        Match[]              @relation("MatchPlayerB")
  matchesWon              Match[]              @relation("MatchWinner")
  matchesLost             Match[]              @relation("MatchLoser")
  confirmations           MatchConfirmation[]
  deckSubmissions         DeckSubmission[]
  challengesAsChallenger  Challenge[]          @relation("ChallengeChallenger")
  challengesAsChallenged  Challenge[]          @relation("ChallengeChallenged")
  codeDistributions       CodeDistribution[]
  playerBadges            PlayerBadge[]
  playerAchievements      PlayerAchievement[]
  rankingSnapshots        RankingSnapshot[]
  tournamentRegistrations TournamentRegistration[]
  gifts                   PlayerGift[]
  badgeProgress           BadgeProgress[]
  wallet                  ZikaCoinWallet?
  inventory               PlayerInventory[]
  betsPlaced              ZikaBet[]             @relation("ZkBetByPlayer")
  betsOn                  ZikaBet[]             @relation("ZkBetOnPlayer")
  stickers                PlayerSticker[]
  achievementEvents       AchievementEvent[]
  zikalootWins            ZikaLoot[]            @relation("ZikaLootWinner")
  zikalootPicks           ZikaLootPick[]
  savedDecks              SavedDeck[]
  mascots                 Mascot[]
  mascotEggs              MascotEgg[]
  mascotIncubator         MascotIncubator?
  mascotFoods             MascotFoodItem[]

  @@map("players")
}

// Torneio independente — pode existir em paralelo a seasons legadas
model Tournament {
  id                    String             @id @default(cuid())
  code                  String?
  name                  String
  slug                  String             @unique
  edition               String?
  description           String?
  format                TournamentFormat   @default(ONLINE)
  status                TournamentStatus   @default(DRAFT)
  startDate             DateTime
  endDate               DateTime?
  maxPlayers            Int?
  matchesPerPlayer      Int?
  requiresDeckSubmission Boolean            @default(true)
  registrationOpensAt   DateTime?
  registrationClosesAt  DateTime?
  bannerImageUrl        String?
  themeMetadata         Json?
  rankingConfig         Json
  seasonId              String?
  announcement          String?
  challengeConfig       Json?
  betConfig             Json?
  narrativeText         String?            @db.Text   // análise geral do campeonato pelo Prof. Enguiça
  narrativeGeneratedAt  DateTime?
  createdById           String
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  createdBy             User               @relation("TournamentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  weeks                 TournamentWeek[]
  registrations         TournamentRegistration[]
  season                Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  deckSubmissions       DeckSubmission[]
  badges                LeagueBadge[]
  challenges            Challenge[]        @relation("TournamentChallenges")
  coinTransactions      ZikaCoinTransaction[] @relation("ZkTxTournament")
  achievements          Achievement[]      @relation("TournamentAchievements")

  @@map("tournaments")
}

// Semanas específicas de um torneio com modo
model TournamentWeek {
  id           String       @id @default(cuid())
  tournamentId String
  weekNumber   Int
  label        String?
  mode         WeekMode     @default(PADRAO)
  multiplier   Decimal      @default(1) @db.Decimal(6, 2)
  bonusRule    Json?
  status       WeekStatus   @default(PLANNED)
  startDate    DateTime
  endDate      DateTime
  lockAt       DateTime?
  deckLockAt   DateTime?
  notes                String?
  narrativeText        String?   @db.Text   // gerado via IA ao encerrar a semana
  narrativeGeneratedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]      @relation("TournamentWeekMatches")
  deckSubmissions  DeckSubmission[]
  challenges       Challenge[]         @relation("TournamentWeekChallenges")
  coinTransactions ZikaCoinTransaction[] @relation("ZkTxWeek")

  @@unique([tournamentId, weekNumber])
  @@map("tournament_weeks")
}

// Inscrição de jogador em torneio
model TournamentRegistration {
  id           String             @id @default(cuid())
  tournamentId String
  playerId     String
  status       RegistrationStatus @default(PENDING)
  registeredAt DateTime           @default(now())
  decidedAt    DateTime?
  decidedById  String?
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  decidedBy    User?              @relation("RegistrationDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([tournamentId, playerId])
  @@map("tournament_registrations")
}

model Season {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  description        String?
  startDate          DateTime
  endDate            DateTime?
  status             SeasonStatus         @default(DRAFT)
  rankingConfig      Json
  topOfDayConfig     Json?
  createdById        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  createdBy          User                 @relation("SeasonCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  seasonPlayers      SeasonPlayer[]
  weeks              Week[]
  tournaments        Tournament[]
  matches            Match[]
  deckSubmissions    DeckSubmission[]
  challenges         Challenge[]
  boosterCodes       BoosterCode[]
  codeDistributions  CodeDistribution[]
  achievements       Achievement[]
  playerAchievements PlayerAchievement[]
  rankingSnapshots   RankingSnapshot[]

  @@map("seasons")
}

model SeasonPlayer {
  id            String    @id @default(cuid())
  seasonId      String
  playerId      String
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  seed          Int?
  initialPoints Decimal?  @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  notes         String?
  season        Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player        Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, playerId])
  @@map("season_players")
}

model Week {
  id               String            @id @default(cuid())
  seasonId         String
  number           Int
  label            String?
  mode             WeekMode          @default(PADRAO)
  startsAt         DateTime
  endsAt           DateTime
  multiplier       Decimal           @default(1) @db.Decimal(6, 2)
  bonusRule        Json?
  lockAt           DateTime?
  status           WeekStatus        @default(PLANNED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  season           Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  matches          Match[]
  deckSubmissions  DeckSubmission[]
  challenges       Challenge[]
  rankingSnapshots RankingSnapshot[]

  @@unique([seasonId, number])
  @@map("weeks")
}

model Match {
  id                String          @id @default(cuid())
  seasonId          String?
  weekId            String?
  tournamentWeekId  String?
  playerAId         String
  playerBId         String?
  isBye             Boolean         @default(false)
  scheduledAt       DateTime?
  playedAt          DateTime?
  roundLabel        String?
  tableLabel        String?
  bestOf            Int             @default(3)
  playerAWins       Int             @default(0)
  playerBWins       Int             @default(0)
  draws             Int             @default(0)
  winnerDefendedPrizes Int           @default(0)
  winnerPlayerId    String?
  loserPlayerId     String?
  playerADeckSubmissionId String?
  playerBDeckSubmissionId String?
  status            MatchStatus     @default(PENDING_CONFIRMATION)
  resultSource      ResultSource    @default(MANUAL)
  rankingPointsA    Decimal         @default(0) @db.Decimal(10, 2)
  rankingPointsB    Decimal         @default(0) @db.Decimal(10, 2)
  topOfDayEligible  Boolean         @default(false)
  notes             String?
  reportedById      String?
  confirmedById     String?
  reportedAt        DateTime?
  confirmedAt       DateTime?
  createdById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  season            Season?         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  week              Week?           @relation(fields: [weekId], references: [id], onDelete: SetNull)
  tournamentWeek    TournamentWeek? @relation("TournamentWeekMatches", fields: [tournamentWeekId], references: [id], onDelete: SetNull)
  playerA           Player          @relation("MatchPlayerA", fields: [playerAId], references: [id], onDelete: Restrict)
  playerB           Player?         @relation("MatchPlayerB", fields: [playerBId], references: [id], onDelete: SetNull)
  winnerPlayer      Player?         @relation("MatchWinner", fields: [winnerPlayerId], references: [id], onDelete: SetNull)
  loserPlayer       Player?         @relation("MatchLoser", fields: [loserPlayerId], references: [id], onDelete: SetNull)
  reportedBy        User?           @relation("MatchReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  confirmedBy       User?           @relation("MatchConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  createdBy         User            @relation("MatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  confirmations     MatchConfirmation[]
  challenges        Challenge[]

  @@index([seasonId, weekId, status])
  playerAOdds      Decimal?              @db.Decimal(6,2)
  playerBOdds      Decimal?              @db.Decimal(6,2)
  betsEnabled      Boolean               @default(false)
  coinTransactions ZikaCoinTransaction[] @relation("ZkTxMatch")
  bets             ZikaBet[]
  @@index([playerAId, playerBId, playedAt])
  @@index([playerADeckSubmissionId])
  @@index([playerBDeckSubmissionId])
  @@map("matches")
}

model MatchConfirmation {
  id          String             @id @default(cuid())
  matchId     String
  playerId    String
  status      ConfirmationStatus @default(PENDING)
  confirmedAt DateTime?
  comment     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("match_confirmations")
}

model DeckSubmission {
  id              String               @id @default(cuid())
  seasonId        String
  weekId          String?
  tournamentId    String?
  tournamentWeekId String?
  playerId        String
  deckNumber      Int                  @default(1)
  deckName        String
  deckList        String
  archetype       String?
  submittedAt     DateTime             @default(now())
  editedAt        DateTime?
  deadlineAt      DateTime
  status          DeckSubmissionStatus @default(SUBMITTED)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  isLate          Boolean              @default(false)
  season          Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  week            Week?                @relation(fields: [weekId], references: [id], onDelete: SetNull)
  tournament      Tournament?          @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  tournamentWeek  TournamentWeek?      @relation(fields: [tournamentWeekId], references: [id], onDelete: SetNull)
  player          Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  approvedBy      User?                @relation("DeckApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([seasonId, weekId, playerId])
  @@index([tournamentWeekId, playerId, deckNumber])
  @@index([tournamentId, tournamentWeekId, status])
  @@map("deck_submissions")
}

model Challenge {
  id               String          @id @default(cuid())
  type             ChallengeType   @default(BADGE)
  seasonId         String?
  tournamentId     String?
  tournamentWeekId String?
  weekId           String?
  matchId          String?
  badgeId          String?
  challengerId     String
  challengedId     String
  openedById       String
  resolvedById     String?
  status           ChallengeStatus @default(OPEN)
  reason           String?
  resolutionNotes  String?
  metadata         Json?
  openedAt         DateTime        @default(now())
  resolvedAt       DateTime?
  season           Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  tournament       Tournament?     @relation("TournamentChallenges", fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentWeek   TournamentWeek? @relation("TournamentWeekChallenges", fields: [tournamentWeekId], references: [id], onDelete: SetNull)
  week             Week?           @relation(fields: [weekId], references: [id], onDelete: SetNull)
  badge            LeagueBadge?    @relation("BadgeChallenges", fields: [badgeId], references: [id], onDelete: SetNull)
  match            Match?          @relation(fields: [matchId], references: [id], onDelete: SetNull)
  challenger       Player          @relation("ChallengeChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged       Player          @relation("ChallengeChallenged", fields: [challengedId], references: [id], onDelete: Cascade)
  openedBy         User            @relation("ChallengeOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  resolvedBy       User?           @relation("ChallengeResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([tournamentId, status])
  @@index([seasonId, status])
  @@map("challenges")
}

model BadgeProgress {
  id        String      @id @default(cuid())
  badgeId   String
  playerId  String
  points    Int         @default(0)
  notes     String?
  updatedAt DateTime    @updatedAt @default(now())
  badge     LeagueBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  player    Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([badgeId, playerId])
  @@map("badge_progress")
}

model LeagueBadge {
  id           String        @id @default(cuid())
  tournamentId String
  name         String
  imageUrl     String        @db.Text
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("LeagueBadgeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  owners       PlayerBadge[]
  challenges   Challenge[]     @relation("BadgeChallenges")
  progress     BadgeProgress[]

  @@index([tournamentId])
  @@map("league_badges")
}

model PlayerBadge {
  id          String      @id @default(cuid())
  badgeId     String
  playerId    String
  awardedById String?
  awardedAt   DateTime    @default(now())
  badge       LeagueBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  awardedBy   User?       @relation("PlayerBadgeAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([badgeId, playerId])
  @@index([playerId])
  @@map("player_badges")
}

model BoosterCode {
  id              String            @id @default(cuid())
  seasonId        String?
  code            String            @unique
  sourceBatch     String?
  rewardLabel     String?
  status          BoosterCodeStatus @default(AVAILABLE)
  importedAt      DateTime          @default(now())
  expiresAt       DateTime?
  notes           String?
  createdById     String
  invalidatedById String?
  invalidatedAt   DateTime?
  season          Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdBy       User              @relation("BoosterCodeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  invalidatedBy   User?             @relation("BoosterCodeInvalidatedBy", fields: [invalidatedById], references: [id], onDelete: SetNull)
  distributions   CodeDistribution[]

  @@map("booster_codes")
}

model CodeDistribution {
  id            String             @id @default(cuid())
  boosterCodeId String             @unique
  seasonId      String?
  playerId      String?
  assignedById  String
  revokedById   String?
  reason        DistributionReason
  reasonDetail  String?
  status        DistributionStatus @default(ASSIGNED)
  assignedAt    DateTime           @default(now())
  redeemedAt    DateTime?
  revokedAt     DateTime?
  boosterCode   BoosterCode        @relation(fields: [boosterCodeId], references: [id], onDelete: Cascade)
  season        Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  player        Player?            @relation(fields: [playerId], references: [id], onDelete: SetNull)
  assignedBy    User               @relation("CodeAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  revokedBy     User?              @relation("CodeRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([seasonId, status])
  @@map("code_distributions")
}

// ── Enums de conquistas ───────────────────────────────────────────────────────

enum AchievementType {
  MANUAL
  AUTOMATIC
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  SECRET
}

enum AchievementCategory {
  TOURNAMENT
  COLLECTION
  SOCIAL
  ENGAGEMENT
  COSMETIC
  SPECIAL
}

enum AchievementScope {
  GLOBAL
  SEASON
  TOURNAMENT
}

enum AchievementRewardType {
  ZIKA_COINS
  LOOT_TICKET
  STICKER_PACK
  SHOP_ITEM
  TITLE_TEXT
  BADGE
}

enum AchievementEventType {
  MATCH_WIN
  MATCH_LOSS
  DECK_SUBMITTED
  COINS_EARNED
  COINS_SPENT
  SHOP_ITEM_PURCHASED
  LOOT_WON
  STICKER_PACK_OPENED
  STICKER_RECEIVED
  GIFT_SENT
  GIFT_RECEIVED
  TITLE_EQUIPPED
  BANNER_EQUIPPED
  FRAME_EQUIPPED
  PROFESSOR_USED
  ALBUM_GENERATION_COMPLETED
  DAILY_LOGIN
}

model Achievement {
  id                 String              @id @default(cuid())
  seasonId           String?
  key                String
  name               String
  description        String?
  icon               String?
  iconUrl            String?             @db.Text
  criteria           Json
  active             Boolean             @default(true)
  // Novos campos
  type               AchievementType     @default(MANUAL)
  rarity             AchievementRarity   @default(COMMON)
  category           AchievementCategory @default(TOURNAMENT)
  scope              AchievementScope    @default(GLOBAL)
  isSecret           Boolean             @default(false)
  isRepeatable       Boolean             @default(false)
  suggestedPoints    Int?
  tournamentId       String?
  createdById        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  season             Season?             @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  tournament         Tournament?         @relation("TournamentAchievements", fields: [tournamentId], references: [id], onDelete: SetNull)
  createdBy          User                @relation("AchievementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  playerAchievements PlayerAchievement[]
  rewards            AchievementReward[]
  rules              AchievementRule[]

  @@unique([seasonId, key])
  @@map("achievements")
}

model AchievementRule {
  id            String               @id @default(cuid())
  achievementId String
  eventType     AchievementEventType
  targetValue   Int                  @default(1)
  metadataFilter Json?
  achievement   Achievement          @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  @@index([achievementId])
  @@map("achievement_rules")
}

model AchievementReward {
  id            String                @id @default(cuid())
  achievementId String
  rewardType    AchievementRewardType
  rewardAmount  Int?
  rewardItemId  String?               // ShopItem.id para cosméticos
  titleText     String?               // para TITLE_TEXT
  deliverViaGift Boolean             @default(true)
  achievement   Achievement          @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  @@map("achievement_rewards")
}

model AchievementEvent {
  id        String               @id @default(cuid())
  playerId  String
  eventType AchievementEventType
  value     Int                  @default(1)
  metadata  Json?
  seasonId  String?
  createdAt DateTime             @default(now())
  player    Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@index([playerId, eventType])
  @@map("achievement_events")
}

model PlayerAchievement {
  id             String       @id @default(cuid())
  achievementId  String
  playerId       String
  seasonId       String?
  awardedById    String?
  awardedAt      DateTime     @default(now())
  notes          String?
  // Novos campos
  pointsAwarded  Int?
  progress       Int          @default(1)
  timesUnlocked  Int          @default(1)
  isHighlighted  Boolean      @default(false)
  weekId         String?
  achievement    Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season         Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  awardedBy      User?        @relation("PlayerAchievementAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([achievementId, playerId, seasonId])
  @@map("player_achievements")
}

model RankingSnapshot {
  id                 String       @id @default(cuid())
  seasonId           String
  weekId             String?
  playerId           String
  snapshotType       SnapshotType @default(WEEKLY)
  points             Decimal      @db.Decimal(10, 2)
  wins               Int          @default(0)
  losses             Int          @default(0)
  draws              Int          @default(0)
  byeCount           Int          @default(0)
  topOfDayCount      Int          @default(0)
  boosterCount       Int          @default(0)
  strengthOfSchedule Decimal      @default(0) @db.Decimal(8, 4)
  tiebreaker1        Decimal      @default(0) @db.Decimal(8, 4)
  tiebreaker2        Decimal      @default(0) @db.Decimal(8, 4)
  position           Int
  basedOnMatchCount  Int          @default(0)
  generatedAt        DateTime     @default(now())
  generatedById      String
  algorithmVersion   String
  configHash         String
  inputHash          String
  auditPayload       Json
  season             Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  week               Week?        @relation(fields: [weekId], references: [id], onDelete: SetNull)
  player             Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  generatedBy        User         @relation("RankingSnapshotGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)

  @@index([seasonId, weekId, generatedAt])
  @@unique([seasonId, weekId, playerId, snapshotType, algorithmVersion, inputHash])
  @@map("ranking_snapshots")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model PlayerGift {
  id          String     @id @default(cuid())
  playerId    String
  type        GiftType   @default(BOOSTER_CODE)
  title       String
  description String?
  payload     Json?      // { code: "...", boosterCodeId: "...", etc }
  status      GiftStatus @default(UNCLAIMED)
  claimedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  player      Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, status])
  @@map("player_gifts")
}

enum GiftType {
  BOOSTER_CODE
  BADGE
  ACHIEVEMENT
  CUSTOM
  STICKER
}

enum GiftStatus {
  UNCLAIMED
  CLAIMED
  EXPIRED
}

// ── Álbum de Figurinhas ───────────────────────────────────────────────────────

enum PokemonRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model PokemonCard {
  id          String        @id @default(cuid())
  nationalId  Int           @unique
  name        String
  displayName String
  generation  Int
  types       String[]
  imageUrl    String?       @db.Text
  rarity      PokemonRarity @default(COMMON)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  stickers    PlayerSticker[]
  @@index([generation])
  @@index([rarity])
  @@map("pokemon_cards")
}

model PlayerSticker {
  id            String      @id @default(cuid())
  playerId      String
  cardId        String
  quantity      Int         @default(1)
  isFavorite    Boolean     @default(false)
  firstObtained DateTime    @default(now())
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  card          PokemonCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  @@unique([playerId, cardId])
  @@index([playerId])
  @@map("player_stickers")
}

model StickerPack {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?  @db.Text
  price       Int
  cardCount   Int      @default(3)
  generation  Int?
  rarityBoost Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@map("sticker_packs")
}

// ── ZikaLoot ──────────────────────────────────────────────────────────────────

model ZikaLoot {
  id          String         @id @default(cuid())
  name        String
  description String?
  prize       String
  drawAt      DateTime
  drawnNumber  Int?
  drawnNumbers Int[]
  prizeConfig  Json?
  status       ZikaLootStatus @default(SCHEDULED)
  winnerId    String?
  createdById String
  createdAt   DateTime       @default(now())
  winner      Player?        @relation("ZikaLootWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  createdBy   User           @relation("ZikaLootCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  picks       ZikaLootPick[]
  @@map("zika_loot")
}

model ZikaLootPick {
  id       String   @id @default(cuid())
  lootId   String
  playerId String
  number   Int
  pickedAt DateTime @default(now())
  loot     ZikaLoot @relation(fields: [lootId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([lootId, number])
  @@index([lootId, playerId])
  @@map("zika_loot_picks")
}

// ── Decks Salvos ──────────────────────────────────────────────────────────────

model SavedDeck {
  id        String   @id @default(cuid())
  playerId  String
  name      String
  archetype String?
  deckList  String   @db.Text
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@index([playerId])
  @@map("saved_decks")
}

// ── ZikaBet ───────────────────────────────────────────────────────────────────

model ZikaBet {
  id              String        @id @default(cuid())
  playerId        String
  matchId         String
  betOnPlayerId   String
  amount          Int
  odds            Decimal       @db.Decimal(6,2)
  potentialReturn Int
  status          ZikaBetStatus @default(OPEN)
  placedAt        DateTime      @default(now())
  settledAt       DateTime?
  player          Player        @relation("ZkBetByPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  betOnPlayer     Player        @relation("ZkBetOnPlayer", fields: [betOnPlayerId], references: [id], onDelete: Cascade)
  @@unique([playerId, matchId])
  @@index([playerId])
  @@index([matchId])
  @@map("zika_bets")
}

// ── ZikaCoins ──────────────────────────────────────────────────────────────────

enum ZikaBetStatus {
  OPEN
  CLOSED
  WON
  LOST
  REFUNDED
  CANCELLED
}

enum ZikaCoinTxType {
  PARTICIPATION_REWARD
  MATCH_WIN_REWARD
  MATCH_LOSS_REWARD
  TOP_DAY_REWARD
  ACHIEVEMENT_REWARD
  BADGE_REWARD
  BET_PLACED
  BET_WON
  BET_LOST
  BET_REFUNDED
  SHOP_PURCHASE
  STICKER_PACK_PURCHASE
  DUPLICATE_STICKER_CONVERSION
  ADMIN_ADJUSTMENT
}

enum ZikaCoinTxStatus {
  COMPLETED
  PENDING
  CANCELLED
}

model ZikaCoinWallet {
  id           String                @id @default(cuid())
  playerId     String                @unique
  balance      Int                   @default(0)
  totalEarned  Int                   @default(0)
  totalSpent   Int                   @default(0)
  updatedAt    DateTime              @updatedAt @default(now())
  player       Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  transactions ZikaCoinTransaction[]
  @@map("zikacoin_wallets")
}

model ZikaCoinTransaction {
  id               String              @id @default(cuid())
  walletId         String
  type             ZikaCoinTxType
  amount           Int
  balanceBefore    Int
  balanceAfter     Int
  description      String?
  tournamentId     String?
  tournamentWeekId String?
  matchId          String?
  adminId          String?
  status           ZikaCoinTxStatus    @default(COMPLETED)
  createdAt        DateTime            @default(now())
  wallet           ZikaCoinWallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tournament       Tournament?         @relation("ZkTxTournament", fields: [tournamentId], references: [id], onDelete: SetNull)
  tournamentWeek   TournamentWeek?     @relation("ZkTxWeek", fields: [tournamentWeekId], references: [id], onDelete: SetNull)
  match            Match?              @relation("ZkTxMatch", fields: [matchId], references: [id], onDelete: SetNull)
  admin            User?               @relation("ZkTxAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  @@index([walletId, createdAt])
  @@map("zikacoin_transactions")
}

// ── Shop ──────────────────────────────────────────────────────────────────────

enum ShopItemType {
  TITLE
  BANNER
  FRAME
  ZIKALOOT_TICKET
  EGG_COMMON
  EGG_RARE
  EGG_SPECIAL
  MASCOT_FOOD
  MASCOT_SWEET
  MASCOT_BUFF_EXP
  MASCOT_BUFF_STAT
  MASCOT_BUFF_HAPPY
  MASCOT_BUFF_LUCK
  MASCOT_BUFF_MOOD
}

enum ZikaLootStatus {
  SCHEDULED
  DRAWN
  NO_WINNER
  CANCELLED
}

enum ShopItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
  RELIC
}

enum TitleTheme {
  NEUTRAL
  ELECTRIC
  FIRE
  WATER
  GRASS
  ZIKABET
}

enum TitleEntranceEffect {
  NONE
  LIGHTNING_STRIKE
  BOSS_ALERT
  CHAMPION_ARENA
  COIN_RAIN
  DIMENSIONAL_RIFT
  ULTRA_RARE_REVEAL
  GLITCH_HACK
  SLOT_MACHINE
  ELEMENTAL_AURA
  MIAUVADAO_SEAL
}

model ShopItem {
  id          String          @id @default(cuid())
  type        ShopItemType
  name        String
  description String?
  imageUrl    String?         @db.Text
  rarity      ShopItemRarity  @default(COMMON)
  price       Int
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)  // ordem de exibição na loja
  // Para molduras (FRAME): { frameScale: number, frameOffsetX: number, frameOffsetY: number }
  // Para banners (BANNER): { focusX: number, focusY: number }
  metadata    Json?
  // Para títulos (TITLE): tema visual, frase de sabor e efeito de entrada
  theme           TitleTheme           @default(NEUTRAL)
  flavorText      String?              @db.Text
  entranceEffect  TitleEntranceEffect  @default(NONE)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User            @relation("ShopItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  ownerships  PlayerInventory[]
  @@map("shop_items")
}

model PlayerInventory {
  id          String    @id @default(cuid())
  playerId    String
  itemId      String
  equipped    Boolean   @default(false)
  quantity    Int       @default(1)
  purchasedAt DateTime  @default(now())
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  @@unique([playerId, itemId])
  @@index([playerId])
  @@map("player_inventory")
}

model UserFcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("user_fcm_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ── Sistema de Mascotes ───────────────────────────────────────────────────────

enum EggType {
  COMMON
  RARE
  SPECIAL
  EVENT
}

enum MascotMood {
  HAPPY
  EXCITED
  NEUTRAL
  TIRED
  NEEDY
  COMPETITIVE
  ANGRY
  PROUD
  HUNGRY
  CONFIDENT
}

enum MascotPersonality {
  LOYAL
  PROUD
  MISCHIEVOUS
  LAZY
  COMPETITIVE
  DRAMATIC
  PLAYFUL
  ELECTRIC
  TIMID
  CHAOTIC
}

enum ExpeditionStatus {
  ACTIVE
  COMPLETED
  CLAIMED
}

enum FoodType {
  FOOD
  SWEET
}

model MascotEgg {
  id         String          @id @default(cuid())
  playerId   String
  type       EggType         @default(COMMON)
  obtainedAt DateTime        @default(now())
  // Se vier de uma conquista/evento, guarda a origem
  origin     String?
  player     Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  incubation MascotIncubator?
  @@index([playerId])
  @@map("mascot_eggs")
}

model MascotIncubator {
  id        String    @id @default(cuid())
  playerId  String    @unique  // 1 incubadora por jogador
  eggId     String    @unique
  startedAt DateTime  @default(now())
  finishAt  DateTime
  hatched   Boolean   @default(false)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  egg       MascotEgg @relation(fields: [eggId], references: [id], onDelete: Cascade)
  @@map("mascot_incubators")
}

model Mascot {
  id               String            @id @default(cuid())
  playerId         String
  pokemonId        Int               // ID da PokéAPI
  nickname         String?
  level            Int               @default(1)
  exp              Int               @default(0)
  happiness        Int               @default(50)  // 0-100
  mood             MascotMood        @default(NEUTRAL)
  personality      MascotPersonality
  isEquipped       Boolean           @default(false)
  // Stats
  statForce        Int               @default(10)
  statAgility      Int               @default(10)
  statCharisma     Int               @default(10)
  statInstinct     Int               @default(10)
  statVitality     Int               @default(10)
  // Batalhas
  battleWins       Int               @default(0)
  battleLosses     Int               @default(0)
  // Timestamps
  hatchedAt        DateTime          @default(now())
  lastInteractedAt DateTime?
  lastFedAt        DateTime?
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  expeditions      MascotExpedition[]
  relationsAsA     MascotRelation[]  @relation("MascotRelationA")
  relationsAsB     MascotRelation[]  @relation("MascotRelationB")
  events           MascotEvent[]
  buffs            MascotBuff[]
  @@index([playerId])
  @@map("mascots")
}

enum MascotRelationType {
  FRIEND
  RIVAL
}

model MascotRelation {
  id        String             @id @default(cuid())
  mascotAId String
  mascotBId String
  type      MascotRelationType @default(RIVAL)
  wins      Int                @default(0)   // vitórias de A sobre B
  losses    Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  mascotA   Mascot             @relation("MascotRelationA", fields: [mascotAId], references: [id], onDelete: Cascade)
  mascotB   Mascot             @relation("MascotRelationB", fields: [mascotBId], references: [id], onDelete: Cascade)
  @@unique([mascotAId, mascotBId])
  @@map("mascot_relations")
}

model MascotEvent {
  id          String   @id @default(cuid())
  mascotId    String
  emoji       String   @default("📝")
  description String
  createdAt   DateTime @default(now())
  mascot      Mascot   @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId, createdAt])
  @@map("mascot_events")
}

model MascotExpedition {
  id         String          @id @default(cuid())
  mascotId   String
  startedAt  DateTime        @default(now())
  finishAt   DateTime
  status     ExpeditionStatus @default(ACTIVE)
  rewardJson Json?
  mascot     Mascot          @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId])
  @@map("mascot_expeditions")
}

enum MascotBuffType {
  EXP_BOOST
  STAT_BOOST
  HAPPINESS
  LUCK_BOOST
  MOOD_RESET
}

model MascotBuff {
  id        String        @id @default(cuid())
  mascotId  String
  type      MascotBuffType
  expiresAt DateTime
  createdAt DateTime      @default(now())
  mascot    Mascot        @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  @@index([mascotId, expiresAt])
  @@map("mascot_buffs")
}

model MascotFoodItem {
  id       String   @id @default(cuid())
  playerId String
  type     FoodType
  quantity Int      @default(1)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([playerId, type])
  @@map("mascot_food_items")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
